{
  "name": "tarshub",
  "version": "1.0.0",
  "description": "Install agent context packages from TarsHub",
  "type": "module",
  "bin": {
    "tarshub": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tarshub/cli"
  },
  "homepage": "https://tarshub.com",
  "keywords": [
    "ai",
    "agent",
    "cursor",
    "rules",
    "context",
    "vibe-coding",
    "llm",
    "copilot"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "npm run build && node dist/cli.js info @prakis/cursorrules-test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
